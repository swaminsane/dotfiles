#!/bin/sh

# Source environment too
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# Only run these in dwm
if [ "$WM" = "dwm" ]; then
    pidof dwmblocks >/dev/null || dwmblocks &
    pidof xsct >/dev/null || xsct 4200 &
#    $HOME/.local/bin/setbg
    dunst &
    feh --bg-fill --randomize $HOME/.local/share/wallpapers/
    nm-applet &
    /usr/bin/kdeconnectd &

fi
