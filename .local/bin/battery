#!/usr/bin/env bash

# Path to battery
BATTERY="/org/freedesktop/UPower/devices/battery_BAT0"

# Get numeric percentage
P=$(upower -i "$BATTERY" | awk '/percentage/ {gsub("%","",$2); print $2}')
# Get state: charging or discharging
S=$(upower -i "$BATTERY" | awk '/state/ {print $2}')

# Determine symbol
if [ "$S" = "charging" ]; then
    SYMBOL="⚡"
    COLOR="\033[32m"  # green
elif [ "$P" -lt 30 ]; then
    SYMBOL="!"
    COLOR="\033[31m"  # red
else
    SYMBOL="-"
    COLOR="\033[0m"   # default
fi

# Print result
echo -e "${COLOR}${P}% ${SYMBOL}\033[0m"
