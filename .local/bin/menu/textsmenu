#!/usr/bin/env bash
# textsmenu — browse local book/PDF libraries via dmenu

# ── Libraries (label → path) ──────────────────────────────────────────────────
declare -A LIBRARIES
LIBRARIES["NCERT"]="$HOME/sync/docs/ncert"
LIBRARIES["Books"]="$HOME/books"
# LIBRARIES["Papers"]="$HOME/sync/papers"
# LIBRARIES["Manga"]="$HOME/sync/manga"

# ── Per-format readers ────────────────────────────────────────────────────────
READER_PDF="${TEXTSMENU_READER_PDF:-zathura}"
READER_CBZ="${TEXTSMENU_READER_CBZ:-zathura}"
READER_CBR="${TEXTSMENU_READER_CBR:-zathura}"
READER_EPUB="${TEXTSMENU_READER_EPUB:-mupdf}"
READER_DJVU="${TEXTSMENU_READER_DJVU:-zathura}"
READER_MOBI="${TEXTSMENU_READER_MOBI:-mupdf}"

# ── Config ────────────────────────────────────────────────────────────────────
LOGFILE="/tmp/textsmenu.log"
RECENT_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/textsmenu_recent"
MAX_RECENT=20

# ── Helpers ───────────────────────────────────────────────────────────────────
notify() {
    notify-send -u "${2:-normal}" -t 3000 -i "document-open" "textsmenu" "$1" 2>/dev/null \
        || echo "[notify] $1" >> "$LOGFILE"
}

dmenu_pick() {
    dmenu -i -l 15 -p "$1"
}

get_reader() {
    case "${1##*.}" in
        pdf)       echo "$READER_PDF"  ;;
        cbz)       echo "$READER_CBZ"  ;;
        cbr)       echo "$READER_CBR"  ;;
        epub)      echo "$READER_EPUB" ;;
        djvu)      echo "$READER_DJVU" ;;
        mobi)      echo "$READER_MOBI" ;;
        *)         echo "$READER_PDF"  ;;   # sane fallback
    esac
}

add_recent() {
    mkdir -p "$(dirname "$RECENT_FILE")"
    touch "$RECENT_FILE"
    grep -vxF "$1" "$RECENT_FILE" | head -n $((MAX_RECENT - 1)) > "${RECENT_FILE}.tmp"
    { echo "$1"; cat "${RECENT_FILE}.tmp"; } > "$RECENT_FILE"
    rm -f "${RECENT_FILE}.tmp"
}

open_file() {
    local path="$1"
    local reader
    reader=$(get_reader "$path")

    if ! command -v "$reader" &>/dev/null; then
        notify "Reader not found: $reader" "critical"
        exit 1
    fi

    add_recent "$path"
    notify "Opening: $(basename "$path")" "low"
    echo "[textsmenu] opening $path with $reader" >> "$LOGFILE"
    "$reader" "$path" &
}

# ── Build top-level menu (Recent + libraries) ─────────────────────────────────
menu_items=$(printf '%s\n' "${!LIBRARIES[@]}" | sort)
[[ -f "$RECENT_FILE" && -s "$RECENT_FILE" ]] && menu_items=$'Recent\n'"$menu_items"

section=$(printf '%s\n' "$menu_items" | dmenu_pick "Library: ") || exit 0
[[ -z "$section" ]] && exit 0

# ── Recent branch ─────────────────────────────────────────────────────────────
if [[ "$section" == "Recent" ]]; then
    chosen=$(dmenu_pick "Recent: " < "$RECENT_FILE") || exit 0
    [[ -z "$chosen" ]] && exit 0

    [[ ! -f "$chosen" ]] && { notify "File no longer exists: $(basename "$chosen")" "critical"; exit 1; }
    open_file "$chosen"
    exit 0
fi

# ── Library branch ────────────────────────────────────────────────────────────
dir="${LIBRARIES[$section]}"

[[ ! -d "$dir" ]] && { notify "Directory not found: $dir" "critical"; exit 1; }

mapfile -t files < <(
    find "$dir" \( \
        -name "*.pdf"  -o -name "*.epub" -o -name "*.djvu" \
        -o -name "*.cbz" -o -name "*.cbr" -o -name "*.mobi" \
    \) -printf "%P\n" | sort   # -printf "%P" avoids the sed pipe entirely
)

[[ ${#files[@]} -eq 0 ]] && { notify "No files found in: $dir" "low"; exit 1; }

chosen=$(printf '%s\n' "${files[@]}" | dmenu_pick "$section: ") || exit 0
[[ -z "$chosen" ]] && exit 0

full_path="$dir/$chosen"
[[ ! -f "$full_path" ]] && { notify "File not found: $chosen" "critical"; exit 1; }

open_file "$full_path"
