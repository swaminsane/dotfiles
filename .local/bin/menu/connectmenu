#!/usr/bin/env bash
# =============================================================================
# network-manager.sh — dmenu Wi-Fi & Bluetooth controller
#
# Dependencies: nmcli, rfkill, systemctl, bluetoothctl, notify-send, dmenu
# =============================================================================

export PATH=/usr/bin:/bin:/usr/sbin:/sbin:$PATH

# ---------------------------------------------------------------------------
# CONFIG — tweak to match your rice
# ---------------------------------------------------------------------------
DMENU_LINES=12
DMENU_PROMPT_ARGS=(-i)
NOTIFY_TIMEOUT=4000

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
_dmenu() {
    local prompt="$1"; shift
    dmenu "${DMENU_PROMPT_ARGS[@]}" -p "$prompt" "$@"
}

_notify() {
    notify-send --expire-time="$NOTIFY_TIMEOUT" "$1" "${2:-}"
}

_require() {
    command -v "$1" &>/dev/null || {
        _notify "Missing dependency" "'$1' not found — install it first"
        exit 1
    }
}

_require nmcli
_require bluetoothctl
_require rfkill
_require notify-send
_require dmenu

# =============================================================================
# TOP-LEVEL MENU
# =============================================================================
CHOICE=$(printf "Wi-Fi\nBluetooth\nCancel" | _dmenu "Network:")
[[ -z "$CHOICE" || "$CHOICE" == "Cancel" ]] && exit 0

# =============================================================================
# WI-FI
# =============================================================================
handle_wifi() {
    local opt
    opt=$(printf "Connect\nDisconnect\nTurn On\nTurn Off\nStatus\nCancel" \
        | _dmenu "Wi-Fi:")
    [[ -z "$opt" || "$opt" == "Cancel" ]] && return 0

    case "$opt" in

    # ------------------------------------------------------------------
    "Turn On")
        nmcli radio wifi on \
            && _notify "Wi-Fi" "Radio enabled" \
            || _notify "Wi-Fi" "Failed to enable radio"
        ;;

    # ------------------------------------------------------------------
    "Turn Off")
        nmcli radio wifi off \
            && _notify "Wi-Fi" "Radio disabled" \
            || _notify "Wi-Fi" "Failed to disable radio"
        ;;

    # ------------------------------------------------------------------
    "Connect")
        # Make sure wifi radio is on
        if [[ $(nmcli radio wifi) != "enabled" ]]; then
            _notify "Wi-Fi" "Radio is off — turn it on first"
            return 0
        fi

        # Rescan (best-effort; ignore errors)
        nmcli dev wifi rescan 2>/dev/null || true
        sleep 1

        # ---- Build SSID list ------------------------------------------------
        local raw_scan
        raw_scan=$(nmcli -g SSID,SIGNAL dev wifi list 2>/dev/null || true)

        if [[ -z "$raw_scan" ]]; then
            _notify "Wi-Fi" "No networks found — is the radio on?"
            return 0
        fi

        # Build "signal SSID" lines, deduplicate keeping best signal
        local scored_ssids
        scored_ssids=$(echo "$raw_scan" \
            | awk -F: '
                NF>=2 {
                    sig = $NF
                    ssid = ""
                    for (i=1; i<NF; i++) ssid = ssid (i==1?"":":") $i
                    if (ssid != "" && ssid != "--")
                        print sig " " ssid
                }
            ' \
            | sort -rn \
            | awk '!seen[$2]++')

        if [[ -z "$scored_ssids" ]]; then
            _notify "Wi-Fi" "No visible networks found"
            return 0
        fi

        # ---- Mark saved profiles --------------------------------------------
        local saved_profiles
        saved_profiles=$(nmcli -g NAME,TYPE connection show 2>/dev/null \
            | awk -F: '$2=="802-11-wireless" { print $1 }' || true)

        # Ensure no wrong interface binding on any saved wifi profile
        echo "$saved_profiles" | while read -r name; do
            nmcli connection modify "$name" connection.interface-name "" 2>/dev/null || true
        done

        # Build display list with [saved] tag and signal %
        local display_list
        display_list=$(echo "$scored_ssids" | while read -r sig ssid; do
            if echo "$saved_profiles" | grep -qxF "$ssid"; then
                printf "[saved] %-36s %s%%\n" "$ssid" "$sig"
            else
                printf "        %-36s %s%%\n" "$ssid" "$sig"
            fi
        done)

        # ---- dmenu pick -----------------------------------------------------
        local selected
        selected=$(echo "$display_list" | _dmenu "Select network:" -l "$DMENU_LINES")
        [[ -z "$selected" ]] && return 0

        # Extract SSID: strip prefix tag and trailing " XX%"
        local ssid
        ssid=$(echo "$selected" \
            | sed 's/^\[saved\] //; s/^        //' \
            | sed 's/[[:space:]]*[0-9]\+%[[:space:]]*$//' \
            | sed 's/[[:space:]]*$//')

        [[ -z "$ssid" ]] && { _notify "Wi-Fi" "Could not parse SSID"; return 1; }

        # ---- Connect logic --------------------------------------------------

        # Saved profile → offer Reconnect or Forget & Reconnect
        if echo "$saved_profiles" | grep -qxF "$ssid"; then
            local action
            action=$(printf "Reconnect\nForget & Reconnect\nCancel" \
                | _dmenu "'$ssid':")
            [[ -z "$action" || "$action" == "Cancel" ]] && return 0

            if [[ "$action" == "Forget & Reconnect" ]]; then
                # Delete saved profile and fall through to fresh password prompt
                nmcli connection delete "$ssid" 2>/dev/null || true
                _notify "Wi-Fi" "Forgotten $ssid — enter new password"
            else
                # Normal reconnect — no password prompt
                _notify "Wi-Fi" "Connecting to $ssid…"
                if nmcli connection up id "$ssid"; then
                    _notify "Wi-Fi" "Connected to $ssid"
                else
                    _notify "Wi-Fi" "Failed — try 'Forget & Reconnect' to update password"
                fi
                return 0
            fi
        fi

        # New network (or just forgotten) — check open vs secured
        local security
        security=$(nmcli --fields SSID,SECURITY dev wifi list 2>/dev/null \
            | tail -n +2 \
            | awk -v target="$ssid" '
                {
                    sec = $NF
                    ssid_col = $0
                    sub(/[[:space:]]+[^[:space:]]+$/, "", ssid_col)
                    gsub(/^[[:space:]]+|[[:space:]]+$/, "", ssid_col)
                    if (ssid_col == target) { print sec; exit }
                }
            ')

        if [[ "$security" == "--" || -z "$security" ]]; then
            _notify "Wi-Fi" "Connecting to $ssid…"
            if nmcli dev wifi connect "$ssid"; then
                _notify "Wi-Fi" "Connected to $ssid"
            else
                _notify "Wi-Fi" "Failed to connect to $ssid"
            fi
        else
            local password
            password=$(printf "" | _dmenu "Password for '$ssid':")
            [[ -z "$password" ]] && return 0

            _notify "Wi-Fi" "Connecting to $ssid…"
            if nmcli dev wifi connect "$ssid" password "$password"; then
                _notify "Wi-Fi" "Connected to $ssid"
            else
                _notify "Wi-Fi" "Wrong password or connection failed"
            fi
        fi
        ;;

    # ------------------------------------------------------------------
    "Disconnect")
        local conn
        conn=$(nmcli -t -f NAME,TYPE connection show --active 2>/dev/null \
            | awk -F: '$2=="802-11-wireless" { print $1; exit }')

        if [[ -z "$conn" ]]; then
            local dev
            dev=$(nmcli -t -f DEVICE,TYPE,STATE dev 2>/dev/null \
                | awk -F: '$2=="wifi" && $3=="connected" { print $1; exit }')
            if [[ -n "$dev" ]]; then
                nmcli device disconnect "$dev" \
                    && _notify "Wi-Fi" "Disconnected ($dev)" \
                    || _notify "Wi-Fi" "Failed to disconnect $dev"
            else
                _notify "Wi-Fi" "No active Wi-Fi connection"
            fi
            return 0
        fi

        nmcli connection down "$conn" \
            && _notify "Wi-Fi" "Disconnected from $conn" \
            || _notify "Wi-Fi" "Failed to disconnect $conn"
        ;;

    # ------------------------------------------------------------------
    "Status")
        local ssid signal ip
        ssid=$(nmcli -t -f ACTIVE,SSID dev wifi 2>/dev/null \
            | awk -F: '/^yes/ { print $2; exit }')

        if [[ -n "$ssid" ]]; then
            signal=$(nmcli -t -f ACTIVE,SIGNAL dev wifi 2>/dev/null \
                | awk -F: '/^yes/ { print $2; exit }')
            ip=$(nmcli -t -f IP4.ADDRESS dev show 2>/dev/null \
                | awk -F: 'NR==1 { print $2 }')
            printf "%s  sig:%s%%  %s" "$ssid" "$signal" "$ip" \
                | _dmenu "Wi-Fi Status:" -l 1
        else
            printf "Not connected" | _dmenu "Wi-Fi Status:" -l 1
        fi
        ;;

    esac
}

# =============================================================================
# BLUETOOTH  (unchanged — working fine)
# =============================================================================
handle_bluetooth() {
    local opt
    opt=$(printf "Turn On\nTurn Off\nConnect\nDisconnect\nStatus\nCancel" \
        | _dmenu "Bluetooth:")
    [[ -z "$opt" || "$opt" == "Cancel" ]] && return 0

    case "$opt" in

    "Turn On")
        rfkill unblock bluetooth && systemctl start bluetooth \
            && _notify "Bluetooth" "Turned ON" \
            || _notify "Bluetooth" "Failed to enable"
        ;;

    "Turn Off")
        rfkill block bluetooth && systemctl stop bluetooth \
            && _notify "Bluetooth" "Turned OFF" \
            || _notify "Bluetooth" "Failed to disable"
        ;;

    "Connect")
        local device_list
        device_list=$(bluetoothctl devices 2>/dev/null \
            | awk '{ $1=""; print $0 }' \
            | sed 's/^ //')

        if [[ -z "$device_list" ]]; then
            printf "No paired devices found" | _dmenu "Bluetooth:" -l 1
            return 0
        fi

        local selected
        selected=$(echo "$device_list" | _dmenu "Connect to:" -l 8)
        [[ -z "$selected" ]] && return 0

        local addr
        addr=$(echo "$selected" | awk '{ print $1 }')

        bluetoothctl connect "$addr" \
            && _notify "Bluetooth" "Connected to $selected" \
            || _notify "Bluetooth" "Failed to connect to $selected"
        ;;

    "Disconnect")
        local connected_list
        connected_list=$(bluetoothctl devices Connected 2>/dev/null \
            | awk '{ $1=""; print $0 }' \
            | sed 's/^ //')

        if [[ -z "$connected_list" ]]; then
            printf "No devices connected" | _dmenu "Bluetooth:" -l 1
            return 0
        fi

        local selected
        selected=$(echo "$connected_list" | _dmenu "Disconnect:" -l 8)
        [[ -z "$selected" ]] && return 0

        local addr
        addr=$(echo "$selected" | awk '{ print $1 }')

        bluetoothctl disconnect "$addr" \
            && _notify "Bluetooth" "Disconnected from $selected" \
            || _notify "Bluetooth" "Failed to disconnect $selected"
        ;;

    "Status")
        local connected_list
        connected_list=$(bluetoothctl devices Connected 2>/dev/null \
            | awk '{ $1=""; print $0 }' \
            | sed 's/^ //')

        if [[ -n "$connected_list" ]]; then
            echo "$connected_list" | _dmenu "BT Connected:" -l 8
        else
            printf "No devices connected" | _dmenu "Bluetooth Status:" -l 1
        fi
        ;;

    esac
}

# =============================================================================
# DISPATCH
# =============================================================================
case "$CHOICE" in
    "Wi-Fi")     handle_wifi      ;;
    "Bluetooth") handle_bluetooth ;;
esac

exit 0
