#!/usr/bin/env bash
# ~/.local/bin/hub
# Opens or attaches to the persistent "hub" tmux session.

SESSION="hub"
TMUX_CMD="tmux -f $HOME/.config/tmux/tmux.conf"
RESURRECT_DIR="$HOME/.local/share/tmux/resurrect"

# If already inside tmux, switch to hub
if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION" 2>/dev/null && exit 0
fi

# If hub session already exists, attach
$TMUX_CMD attach-session -t "$SESSION" 2>/dev/null && exit 0

# Check for a saved resurrect file containing hub
SAVE_FILE="$RESURRECT_DIR/last"
if [ -f "$SAVE_FILE" ] && grep -q "$SESSION" "$SAVE_FILE"; then
    $TMUX_CMD new-session -d -s "$SESSION" -n "tmp"
    "$HOME/.config/tmux/plugins/tmux-resurrect/scripts/restore.sh" 2>/dev/null
    sleep 2
    tmux kill-window -t "$SESSION:tmp" 2>/dev/null
    $TMUX_CMD attach-session -t "$SESSION"
    exit 0
fi

# No saved session — build fresh layout
$TMUX_CMD new-session -d -s "$SESSION" -n "main"

# Window 1: main — dual split
tmux send-keys -t "$SESSION:1" "cd ~" Enter
tmux split-window -h -t "$SESSION:1"
tmux send-keys -t "$SESSION:1.2" "cd ~" Enter
tmux select-pane -t "$SESSION:1.1"

# Window 2: c-learning
tmux new-window -t "$SESSION" -n "c" -c "$HOME/sync/docs/learning/c"
tmux split-window -h -t "$SESSION:2"
tmux send-keys -t "$SESSION:2.1" "nvim ." Enter
tmux send-keys -t "$SESSION:2.2" "cd $HOME/sync/docs/learning/c" Enter
tmux select-pane -t "$SESSION:2.1"

# Window 3: builds
tmux new-window -t "$SESSION" -n "src" -c "$HOME/.local/src"
tmux split-window -h -t "$SESSION:3"
tmux send-keys -t "$SESSION:3.1" "nvim ." Enter
tmux send-keys -t "$SESSION:3.2" "cd $HOME/.local/src" Enter
tmux select-pane -t "$SESSION:3.1"

tmux select-window -t "$SESSION:1"
$TMUX_CMD attach-session -t "$SESSION"
